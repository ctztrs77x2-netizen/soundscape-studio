{
  "manifest_version": 3,
  "name": "SoundScape Studio",
  "version": "1.0.0",
  "description": "An immersive premium focus workspace featuring an ambient sound mixer, dynamic Pomodoro timer, notepad, and task checklist.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://api.lemonsqueezy.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {},
  "side_panel": {
    "default_path": "index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; media-src 'self' https://raw.githubusercontent.com;"
  }
}
